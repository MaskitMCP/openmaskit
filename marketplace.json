[
  {
    "id": "slack",
    "name": "Slack",
    "description": "Team messaging, channels, and workspace management",
    "icon": "messaging",
    "official": true,
    "tags": [
      "communication",
      "messaging",
      "team"
    ],
    "transport": "http",
    "url": "https://mcp.slack.com/mcp",
    "oauth": {},
    "oauth_vars": [
      "client_id",
      "client_secret"
    ],
    "env_vars": []
  },
  {
    "id": "postgres",
    "name": "PostgreSQL",
    "description": "Query and manage PostgreSQL databases",
    "icon": "database",
    "official": false,
    "tags": [
      "database",
      "sql",
      "postgres"
    ],
    "transport": "stdio",
    "command": "podman",
    "args": [
      "run",
      "-i",
      "--rm",
      "-e",
      "DATABASE_URI",
      "crystaldba/postgres-mcp",
      "--access-mode=unrestricted"
    ],
    "env_vars": [
      "DATABASE_URI"
    ]
  }
]
